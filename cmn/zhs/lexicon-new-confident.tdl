下载_v_1 := v_np_le &
  [ STEM < "下载" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "下", LENGTH two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_下载_v_1_rel" ],
    TRAITS native_token_list ].

; 严重破坏 (to severely damage/destroy) is a transitive verb. In examples: 严重破坏了连接...的桥梁, 遭到了严重破坏. Takes NP objects.
严重破坏_v_1 := v_np_le &
  [ STEM < "严重破坏" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "严", LENGTH more-than-two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_严重破坏_v_1_rel" ],
    TRAITS native_token_list ].

; 中场 (halftime/midfield) is a common noun used attributively in 中场表演 (halftime show).
中场_n_1 := n_-_le &
  [ STEM < "中场" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "中", LENGTH two ],
    SYNSEM.LKEYS.KEYREL.PRED "_中场_n_1_rel",
    TRAITS native_token_list ].

; 中美关系 (Sino-US relations) is a common noun. Used as object in 发展中美关系, and as subject in 中美关系紧张.
中美关系_n_1 := n_-_le &
  [ STEM < "中美关系" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "中", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.PRED "_中美关系_n_1_rel",
    TRAITS native_token_list ].

; 乐队 (band/musical group) is a common noun. Used as subject and object in the examples.
乐队_n_1 := n_-_le &
  [ STEM < "乐队" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "乐", LENGTH two ],
    SYNSEM.LKEYS.KEYREL.PRED "_乐队_n_1_rel",
    TRAITS native_token_list ].

; 事后 (afterwards/after the event) is a time noun that can function as a temporal adverb, appearing sentence-initially as a time adjunct (事后为他的行为道歉).
事后_n_1 := n_-_tm_le &
  [ STEM < "事后" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "事", LENGTH two ],
    SYNSEM.LKEYS.KEYREL.PRED "_事后_n_1_rel",
    TRAITS native_token_list ].

; 以至于 (so much so that / to the extent that) is a subordinating conjunction that introduces a result clause. It appears before the subordinate clause, making it a pre-head subordinating conjunction.
以至于_conj_1 := conj_-_sub-pre_le &
  [ STEM < "以至于" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "以", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.PRED "_以至于_conj_1_rel",
    TRAITS native_token_list ].

; 修正案 (amendment) is a common noun referring to legal amendments. It functions as a typical noun in all examples.
修正案_n_1 := n_-_le &
  [ STEM < "修正案" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "修", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.PRED "_修正案_n_1_rel",
    TRAITS native_token_list ].

; 倒计时 (countdown) is a common noun used as an object or modifier in the examples (e.g., 倒计时直播, 以倒计时的形式). It functions as a general noun.
倒计时_n_1 := n_-_le &
  [ STEM < "倒计时" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "倒", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.PRED "_倒计时_n_1_rel",
    TRAITS native_token_list ].

; 党派 (political party/faction) is a common noun referring to political parties or factions. Used as a typical noun in all examples.
党派_n_1 := n_-_le &
  [ STEM < "党派" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "党", LENGTH two ],
    SYNSEM.LKEYS.KEYREL.PRED "_党派_n_1_rel",
    TRAITS native_token_list ].

; 入院 (to be admitted to hospital) is an intransitive verb. In the examples it takes no object — the cause is marked with 因 (a preposition), not as a direct object.
入院_v_1 := v_-_le &
  [ STEM < "入院" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "入", LENGTH two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_入院_v_1_rel" ],
    TRAITS native_token_list ].

; 全球性 (global) is an adjective that modifies nouns (全球性的庆祝活动, 全球性挑战, 全球性的视觉语言). It describes a property and functions as a predicative adjective.
全球性_j_1 := a_-_pred_le &
  [ STEM < "全球性" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "全", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.PRED "_全球性_a_1_rel",
    TRAITS native_token_list ].

; 利比亚 (Libya) is a country name, clearly a location proper noun.
利比亚_n_1 := n_-_l_pn_le &
  [ STEM < "利比亚" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "利", LENGTH more-than-two ],
    SYNSEM.LKEYS.KEYREL.CARG "利比亚",
    TRAITS native_token_list ].

; 加重 (to aggravate/worsen) takes an NP complement in the examples (加重空气质量问题), making it a transitive verb.
加重_v_1 := v_np_le &
  [ STEM < "加重" >,
    SYNSEM.LOCAL.CAT.HEAD.CHAR [ FCHAR "加", LENGTH two ],
    SYNSEM [ LKEYS.KEYREL.PRED "_加重_v_1_rel" ],
